{% extends 'layouts/landing.html.twig' %}

{% block content %}
  <main class="pi-site">
    <section class="pi-page-hero">
      <div class="pi-page-hero__media">
        <img src="/img/all-images/about/about-img3.png" alt="Future hospitality spaces" />
      </div>
      <div class="container">
        <div class="row">
          <div class="col-lg-7">
            <div class="pi-eyebrow"><span class="pi-logo-mark"></span> Stays and Spaces</div>
            <h1>Spaces designed to host more value.</h1>
            <p>We look at spaces through guest experience, event readiness, operating flow, and the growth potential behind each asset.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="pi-spaces">
      <div class="container">
        <div class="pi-spaces__grid">
          <div class="pi-spaces__content heading3">
            <h5>Approach</h5>
            <h2>From available property to investable hospitality experience.</h2>
            <p>Our work sits between the details people feel during a stay and the systems that make a hospitality space easier to sell, host, and grow.</p>
          </div>
          <div class="pi-spaces__image pi-spaces__image--large">
            <img src="/img/all-images/others/others-img8.png" alt="Flexible event-ready space" />
          </div>
          <div class="pi-spaces__image">
            <img src="/img/all-images/property/property-img5.png" alt="Prepared guest stay" />
          </div>
          <div class="pi-spaces__metric">
            <strong><i class="fa-solid fa-door-open"></i></strong>
            <span>Built for guest stays, hosted events, operator partnerships, and future investment opportunities.</span>
          </div>
        </div>
      </div>
    </section>
  </main>
{% endblock %}
