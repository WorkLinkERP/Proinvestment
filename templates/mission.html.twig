{% extends 'layouts/landing.html.twig' %}

{% block content %}
  <main class="pi-site">
    <section class="pi-page-hero pi-page-hero--mission">
      <div class="pi-page-hero__media">
        <img src="/img/all-images/property/property-img4.png" alt="Hospitality mission" />
      </div>
      <div class="container">
        <div class="row">
          <div class="col-lg-7">
            <div class="pi-eyebrow"><span class="pi-logo-mark"></span> Mission and Vision</div>
            <h1>Smart investments for future stays and spaces.</h1>
            <p>ProInvestments exists to empower hospitality through practical investment thinking, sharper guest experiences, and spaces that can grow beyond one use case.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="pi-intro sp6">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-lg-6">
            <div class="heading3 pi-copy">
              <h5>Mission</h5>
              <h2>Empowering hospitality through smart investments.</h2>
              <p>We help hospitality operators, hosts, and partners turn promising spaces into assets with stronger guest value and clearer commercial purpose.</p>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="pi-feature-panel">
              <span><i class="fa-solid fa-compass"></i></span>
              <h3>Vision</h3>
              <p>Shaping the future stays and spaces by connecting hosting quality, event readiness, and sustainable growth strategy.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
{% endblock %}
