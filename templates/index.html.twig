{% extends 'layouts/landing.html.twig' %}

{% block content %}
  <main class="pi-site">
    <section class="pi-hero" id="home">
      <div class="pi-hero__media">
        <img src="/img/all-images/hero/hero-img6.png" alt="Hospitality investment space" />
      </div>
      <div class="pi-hero__veil"></div>
      <div class="container">
        <div class="row align-items-end">
          <div class="col-lg-7">
            <div class="pi-eyebrow"><span class="pi-logo-mark"></span> Founded 2025 in Johannesburg, South Africa</div>
            <h1>ProInvestments</h1>
            <p class="pi-hero__lead">Empowering hospitality through smart investments, practical hosting systems, and event-ready spaces built for future stays.</p>
            <div class="pi-hero__actions">
              <a href="/services" class="header-btn3">Explore Services</a>
              <a href="/contact" class="pi-link-button">Start a Conversation <i class="fa-solid fa-arrow-right"></i></a>
            </div>
          </div>
          <div class="col-lg-5">
            <div class="pi-hero__signal">
              <span>Vision</span>
              <strong>Shaping the future stays and spaces.</strong>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="pi-intro sp6" id="about">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-lg-5">
            <div class="pi-photo-stack">
              <img src="/img/all-images/property/property-img4.png" alt="Hosted accommodation lounge" />
              <img src="/img/all-images/property/property-img5.png" alt="Prepared guest space" />
              <div class="pi-photo-stack__badge">
                <span>2025</span>
                <p>Built in Johannesburg for hospitality operators, hosts, and growth partners.</p>
              </div>
            </div>
          </div>
          <div class="col-lg-1"></div>
          <div class="col-lg-6">
            <div class="heading3 pi-copy">
              <h5>Mission</h5>
              <h2>Smart investment for hospitality that actually moves.</h2>
              <p>ProInvestments helps transform promising spaces into high-performing guest, event, and hospitality assets. We bring together hosting operations, space positioning, and growth strategy so properties become useful, memorable, and commercially sharper.</p>
              <p>We are building a separate investment platform from ProConsultants while keeping the relationship clear: ProConsultants is one of our first clients and strategic collaborators.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="pi-services sp1" id="services">
      <div class="container">
        <div class="row">
          <div class="col-lg-7">
            <div class="heading3 space-margin60">
              <h5>Services</h5>
              <h2>Three ways we make hospitality spaces work harder.</h2>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="col-lg-4 col-md-6">
            <article class="pi-service-card">
              <span class="pi-service-card__icon"><i class="fa-solid fa-bell-concierge"></i></span>
              <p>01</p>
              <h3>Guest Hosting</h3>
              <span>Host-ready operations for stays that feel polished, responsive, and commercially intentional.</span>
            </article>
          </div>
          <div class="col-lg-4 col-md-6">
            <article class="pi-service-card pi-service-card--dark">
              <span class="pi-service-card__icon"><i class="fa-solid fa-champagne-glasses"></i></span>
              <p>02</p>
              <h3>Event Space Solutions</h3>
              <span>Positioning, setup logic, and partner pathways for spaces that can host more than overnight guests.</span>
            </article>
          </div>
          <div class="col-lg-4 col-md-6">
            <article class="pi-service-card">
              <span class="pi-service-card__icon"><i class="fa-solid fa-chart-line"></i></span>
              <p>03</p>
              <h3>Growth Strategy</h3>
              <span>Clearer offers, sharper partnerships, and practical investment thinking for hospitality growth.</span>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="pi-spaces" id="spaces">
      <div class="container">
        <div class="pi-spaces__grid">
          <div class="pi-spaces__content heading3">
            <h5>Stays and spaces</h5>
            <h2>From available property to investable hospitality experience.</h2>
            <p>Our work sits between guest experience and commercial strategy: the details people feel during a stay, and the systems that make the asset easier to grow.</p>
          </div>
          <div class="pi-spaces__image pi-spaces__image--large">
            <img src="/img/all-images/about/about-img3.png" alt="Modern hospitality interior" />
          </div>
          <div class="pi-spaces__image">
            <img src="/img/all-images/others/others-img8.png" alt="Event ready hospitality space" />
          </div>
          <div class="pi-spaces__metric">
            <strong>4</strong>
            <span>Client groups: ProConsultants, Travel and Guests, event hosts, and future partners.</span>
          </div>
        </div>
      </div>
    </section>

    <section class="pi-clients sp6" id="partners">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-lg-5">
            <div class="heading3">
              <h5>Clients</h5>
              <h2>Built for partners shaping hospitality in South Africa.</h2>
            </div>
          </div>
          <div class="col-lg-7">
            <div class="pi-client-list">
              <span><i class="fa-solid fa-briefcase"></i> ProConsultants</span>
              <span><i class="fa-solid fa-suitcase-rolling"></i> Travel and Guests</span>
              <span><i class="fa-solid fa-calendar-check"></i> Event Hosts</span>
              <span><i class="fa-solid fa-handshake"></i> Future Partners</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="pi-contact-strip" id="contact">
      <div class="container">
        <div class="pi-contact-strip__inner">
          <div>
            <span>Contact</span>
            <h2>Let us build the public launch channels next.</h2>
          </div>
          <div class="pi-contact-strip__links">
            <a href="mailto:info@proinvestments.co.za">info@proinvestments.co.za</a>
            <a href="https://www.proinvestments.co.za">www.proinvestments.co.za</a>
          </div>
        </div>
      </div>
    </section>
  </main>
{% endblock %}
