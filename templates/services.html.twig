{% extends 'layouts/landing.html.twig' %}

{% block content %}
  <main class="pi-site">
    <section class="pi-page-hero">
      <div class="pi-page-hero__media">
        <img src="/img/all-images/service/service-img11.png" alt="ProInvestments services" />
      </div>
      <div class="container">
        <div class="row">
          <div class="col-lg-7">
            <div class="pi-eyebrow"><span class="pi-logo-mark"></span> Services</div>
            <h1>Hospitality support with investment logic.</h1>
            <p>Guest hosting, event space solutions, and growth strategy delivered as one connected operating mindset.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="pi-services sp6">
      <div class="container">
        <div class="row">
          <div class="col-lg-4 col-md-6">
            <article class="pi-service-card">
              <span class="pi-service-card__icon"><i class="fa-solid fa-bell-concierge"></i></span>
              <p>01</p>
              <h3>Guest Hosting</h3>
              <span>Host-ready systems, care standards, and repeatable stay experiences that help properties feel managed and memorable.</span>
            </article>
          </div>
          <div class="col-lg-4 col-md-6">
            <article class="pi-service-card pi-service-card--dark">
              <span class="pi-service-card__icon"><i class="fa-solid fa-champagne-glasses"></i></span>
              <p>02</p>
              <h3>Event Space Solutions</h3>
              <span>Space positioning, hosting readiness, and partner pathways for event hosts and flexible hospitality uses.</span>
            </article>
          </div>
          <div class="col-lg-4 col-md-6">
            <article class="pi-service-card">
              <span class="pi-service-card__icon"><i class="fa-solid fa-chart-line"></i></span>
              <p>03</p>
              <h3>Growth Strategy</h3>
              <span>Clearer offers, sharper partnerships, and investment thinking that helps hospitality assets mature.</span>
            </article>
          </div>
        </div>
      </div>
    </section>
  </main>
{% endblock %}
